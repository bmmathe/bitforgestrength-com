{
  "hosting": {
    "site": "bitforgestrength",
    "public": "docs",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      {
        "source": "/index",
        "destination": "/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**/*.{js,css,png,jpg,jpeg,gif,webp,svg,woff,woff2}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
